{
  "name": "codex-meter",
  "version": "0.2.3",
  "author": "Helo Chang",
  "homepage": "https://github.com/cyrilchang-0306/codexmeter",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyrilchang-0306/codexmeter.git"
  },
  "description": "A macOS desktop meter for Codex rate limits.",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "clean": "node scripts/clean.js",
    "build": "npm run clean && npm run typecheck && npm run build:main && npm run build:renderer",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "icon": "zsh scripts/generate-icon.sh",
    "dist": "npm run build && electron-builder --mac dmg zip"
  },
  "build": {
    "appId": "com.codexmeter.app",
    "productName": "Codex Meter",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "dist/shared/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Codex Meter ${version}"
    }
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "concurrently": "^9.1.2",
    "electron": "^41.7.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3",
    "wait-on": "^8.0.3"
  }
}
